###
echo "🚀 Creating Deployment..."
set -x
cat <<EOF | kubectl apply -f -
apiVersion: apps/v1
kind: Deployment
metadata:
  name: ${INSTANCE}
  namespace: ${INSTANCE}
  labels:
    app: ${INSTANCE}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: ${INSTANCE}
  strategy:
    type: Recreate 
  template:
    metadata:
      labels:
        app: ${INSTANCE}
    spec:
      securityContext:
        runAsUser: 1000
        runAsGroup: 1000
        fsGroup: 1000
      
      # Copies your initial JSON template to the writable PVC on the first run
      initContainers:
      - name: init-config
        image: busybox
        command: ['sh', '-c', 'cp /tmp/config/openclaw.json /home/node/.openclaw/openclaw.json; chown 1000:1000 /home/node/.openclaw/openclaw.json']
        volumeMounts:
        - name: config-template
          mountPath: /tmp/config
        - name: workspace
          mountPath: /home/node/.openclaw
      containers:
      - name: ${INSTANCE}
        image: ghcr.io/openclaw/openclaw:latest
        ports:
        - containerPort: 18789
          name: gateway
        env:
        - name: OLLAMA_API_KEY
          value: "ollama-local"
        - name: OLLAMA_BASE_URL
          value: "http://${LOCAL_IP}:11434"
        - name: NODE_ENV
          value: "production"
        - name: SLACK_BOT_TOKEN
          valueFrom:
            secretKeyRef:
              name: ${INSTANCE}-secrets
              key: slack-bot-token
        - name: SLACK_APP_TOKEN        # ADDED THIS: Needed for Socket Mode
          valueFrom:
            secretKeyRef:
              name: ${INSTANCE}-secrets
              key: slack-app-token
        - name: OPENCLAW_GATEWAY_TOKEN # Uses your Secret for the Web UI login
          valueFrom:
            secretKeyRef:
              name: ${INSTANCE}-secrets
              key: gateway-token
        - name: OPENCLAW_CONFIG_PATH
          value: "/home/node/.openclaw/openclaw.json"
        volumeMounts:
        - name: workspace
          mountPath: /home/node/.openclaw
        resources:
          requests:
            memory: "512Mi"
            cpu: "250m"
          limits:
            memory: "2Gi"
            cpu: "1"
        livenessProbe:
          httpGet:
            path: /health
            port: 18789
          initialDelaySeconds: 30
          periodSeconds: 10
        readinessProbe:
          httpGet:
            path: /health
            port: 18789
          initialDelaySeconds: 15
          periodSeconds: 5
      volumes:
      - name: config-template
        configMap:
          name: ${INSTANCE}-config
      - name: workspace
        persistentVolumeClaim:
          claimName: ${INSTANCE}-workspace
EOF
