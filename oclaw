###
echo "🚀 Creating Deployment..."
set -x
cat <<EOF | kubectl apply -f -
apiVersion: apps/v1
kind: Deployment
metadata:
  name: ${INSTANCE}
  namespace: ${INSTANCE}
  labels:
    app: ${INSTANCE}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: ${INSTANCE}
  strategy:
    type: RollingUpdate
    rollingUpdate:
      maxSurge: 0        # Never spin up extra pod during update
      maxUnavailable: 1  # Take down old pod BEFORE starting new one
  template:
    metadata:
      labels:
        app: ${INSTANCE}
    spec:
      securityContext:
        runAsUser: 1000
        runAsGroup: 1000
        fsGroup: 1000
      containers:
      - name: ${INSTANCE}
        image: ghcr.io/openclaw/openclaw:latest
        ports:
        - containerPort: 18789
          name: gateway
        env:
        - name: NODE_ENV
          value: "production"
        - name: ANTHROPIC_API_KEY
          valueFrom:
            secretKeyRef:
              name: ${INSTANCE}-secrets
              key: anthropic-api-key
        - name: DISCORD_BOT_TOKEN
          valueFrom:
            secretKeyRef:
              name: ${INSTANCE}-secrets
              key: discord-bot-token
        - name: OPENCLAW_CONFIG_PATH
          value: "/home/node/config/openclaw.json"
        volumeMounts:
        - name: config
          mountPath: /home/node/config/openclaw.json
          subPath: ${INSTANCE}.json
        - name: workspace
          mountPath: /home/node/.openclaw
        resources:
          requests:
            memory: "512Mi"
            cpu: "250m"
          limits:
            memory: "2Gi"
            cpu: "1"
        livenessProbe:
          httpGet:
            path: /health
            port: 18789
          initialDelaySeconds: 30
          periodSeconds: 10
          failureThreshold: 3
        readinessProbe:
          httpGet:
            path: /health
            port: 18789
          initialDelaySeconds: 15
          periodSeconds: 5
          failureThreshold: 3
      volumes:
      - name: config
        configMap:
          name: ${INSTANCE}-config
      - name: workspace
        persistentVolumeClaim:
          claimName: ${INSTANCE}-workspace
EOF
