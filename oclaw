echo "🚀 Creating Service..."
cat <<EOF | kubectl apply -f - 
# service.yaml
apiVersion: v1
kind: Service
metadata:
  name: ${INSTANCE}-service
  namespace: ${INSTANCE}
  labels:
    app: ${INSTANCE}
spec:
  selector:
    app: ${INSTANCE}
  ports:
  - name: gateway
    port: 18789
    targetPort: 18789
  type: ClusterIP
EOF
echo ""   

echo "Press Enter to continue..." ; read

###
echo "🚀 Creating Ingress..."
set -x
cat <<EOF | kubectl apply -f -
# ingress.yaml
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: ${INSTANCE}-ingress
  namespace: ${INSTANCE}
  annotations:
    nginx.ingress.kubernetes.io/rewrite-target: /
    # Add TLS/SSL annotations as needed
spec:
  ingressClassName: nginx
  rules:
  -  http:
      paths:
      - path: /
        pathType: Prefix
        backend:
          service:
            name: ${INSTANCE}-service
            port:
              number: 18789
EOF
