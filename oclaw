###
echo "🚀 Creating Open Claw Configmap..."
set -x
cat <<EOF | kubectl apply -f -
apiVersion: v1
kind: ConfigMap
metadata:
  name: ${INSTANCE}-config
  namespace: ${INSTANCE}
data:
  openclaw.json: |
    {
      "models": {
        "providers": {
          "ollama": {
            "baseUrl": "http://${LOCAL_IP}:11434/v1",
            "apiKey": "ollama-local",
            "api": "openai-responses",
