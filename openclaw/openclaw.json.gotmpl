{
  "models": {
    "providers": {
      "ollama": {
        "baseUrl": "http://{{ .Values.localIp }}:11434",
        "apiKey": "ollama-local",
        "api": "openai-responses",
        "models": [
          {
            "id": "codellama:latest",
            "name": "Code Llama",
            "contextWindow": 16384
          },
          {
            "id": "llama3.1:8b",
            "name": "Llama 3.1 8B",
            "contextWindow": 131072
          },
          {
            "id": "llama3.1:latest",
            "name": "Llama 3.1",
            "contextWindow": 131072
          },
          {
            "id": "llama3.2:latest",
            "name": "Llama 3.2",
            "contextWindow": 131072
          },
          {
            "id": "qwen2.5-coder:14b",
            "name": "Qwen 2.5 Coder 14B",
            "contextWindow": 131072
          },
          {
            "id": "qwen2.5-coder:32b",
            "name": "Qwen 2.5 Coder 32B",
            "contextWindow": 131072
          },
          {
            "id": "qwen2.5:14b",
            "name": "Qwen 2.5 14B",
            "contextWindow": 131072
          },
          {
            "id": "qwen2.5:14b-instruct-q8_0",
            "name": "Qwen 2.5 14B Instruct Q8",
            "contextWindow": 131072
          },
          {
            "id": "qwen3:4b",
            "name": "Qwen3 4B",
            "contextWindow": 32768
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "workspace": "/home/node/.openclaw/workspace",
      "model": {
        "primary": "ollama/llama3.1:latest",
        "fallbacks": [
          "ollama/codellama:latest",
          "ollama/llama3.1:8b",
          "ollama/llama3.2:latest",
          "ollama/qwen2.5-coder:14b",
          "ollama/qwen2.5-coder:32b",
          "ollama/qwen2.5:14b",
          "ollama/qwen2.5:14b-instruct-q8_0",
          "ollama/qwen3:4b"
        ],
      }
    }
  },
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "port": 18789,
    "auth": {
      "mode": "token",
      "rateLimit": {
        "maxAttempts": 30,
        "windowMs": 60000,
        "lockoutMs": 300000
      }
    },
    "controlUi": {
      "allowedOrigins": [
        "http://localhost:18789", 
        "http://{{ .Values.localIp }}:18789", 
        "http://127.0.0.1:18789"
      ]
    }
  },
  "channels": {
    "slack": {
      "enabled": true,
      "mode": "socket",
      "botToken": "",
      "appToken": ""
    }
  }
}
